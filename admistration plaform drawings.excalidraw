      "versionNonce": 1257950330,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1780053895675,
      "link": null,
      "locked": false,
      "text": "\nTyping indicators\nWebSocket\n\"Manager 1 is typing…\" shown in real time. Classic use case for WebSocket heartbeats.",
      "fontSize": 36,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "\nTyping indicators\nWebSocket\n\"Manager 1 is typing…\" shown in real time. Classic use case for WebSocket heartbeats.",
      "autoResize": true,
      "lineHeight": 1.25
    },
