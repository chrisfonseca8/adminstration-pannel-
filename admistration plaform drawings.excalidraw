      "versionNonce": 126322918,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1780053969356,
      "link": null,
      "locked": false,
      "text": "\nRole-based permissions\nAuth\nVP can see all rooms; a manager only sees their assigned rooms. Enforced server-side on every request.\n",
      "fontSize": 36,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "\nRole-based permissions\nAuth\nVP can see all rooms; a manager only sees their assigned rooms. Enforced server-side on every request.\n",
      "autoResize": true,
      "lineHeight": 1.25
    },
