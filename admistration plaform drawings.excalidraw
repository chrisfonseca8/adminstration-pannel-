      "seed": 76822374,
      "version": 628,
      "versionNonce": 522575418,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1780052253943,
      "link": null,
      "locked": false,
      "text": "1. deciding the features of the project\n> user can create mutiple rooms for mutiple projects \n    such as if he manages 5 teams he can create \n    5 rooms \n\n> for each room he creates he can send request to other members\n    to be part of that room \n    EG: manager1:{ employe1, employe2, employe3}(ROOM 1)\n                     {employee 2, employee 5,employe 4,employe 10}(ROOM2)\n                                    .\n                                    .\n                                    .\n    \n    that manger can be part of a team also \n    EG: senior1:{manager 1,manager 3.....}(Room7) \n                            .\n                            .\n                            .                               ",
      "fontSize": 36,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "1. deciding the features of the project\n> user can create mutiple rooms for mutiple projects \n    such as if he manages 5 teams he can create \n    5 rooms \n\n> for each room he creates he can send request to other members\n    to be part of that room \n    EG: manager1:{ employe1, employe2, employe3}(ROOM 1)\n                     {employee 2, employee 5,employe 4,employe 10}(ROOM2)\n                                    .\n                                    .\n                                    .\n    \n    that manger can be part of a team also \n    EG: senior1:{manager 1,manager 3.....}(Room7) \n                            .\n                            .\n                            .                               ",
      "autoResize": true,
      "lineHeight": 1.25
    },
