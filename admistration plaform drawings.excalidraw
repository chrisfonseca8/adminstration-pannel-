      "isDeleted": false,
      "boundElements": [],
      "updated": 1780053931354,
      "link": null,
      "locked": false,
      "text": "\nActivity log / audit trail\nBullMQ\nEvery action (task created, message sent, meeting called) logged asynchronously via a queue job",
      "fontSize": 36,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "\nActivity log / audit trail\nBullMQ\nEvery action (task created, message sent, meeting called) logged asynchronously via a queue job",
      "autoResize": true,
      "lineHeight": 1.25
    },
