      "boundElements": [],
      "updated": 1780053948559,
      "link": null,
      "locked": false,
      "text": "\nMeeting scheduling\nBullMQ\nSchedule a future meeting — queues a job to send invites at the right time, not immediately.",
      "fontSize": 36,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "\nMeeting scheduling\nBullMQ\nSchedule a future meeting — queues a job to send invites at the right time, not immediately.",
      "autoResize": true,
      "lineHeight": 1.25
    },
