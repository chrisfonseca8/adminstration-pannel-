      "updated": 1780053885237,
      "link": null,
      "locked": false,
      "text": "\nThreaded comments\nWebSocket\nReply to specific messages in a room thread. Useful for task discussions or meeting follow-ups.\n\n",
      "fontSize": 36,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "\nThreaded comments\nWebSocket\nReply to specific messages in a room thread. Useful for task discussions or meeting follow-ups.\n\n",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "MY7zlKwAOvTo44B3q0D5q",
      "type": "text",
      "x": -16505.30360389991,
      "y": -9553.091418261298,
      "width": 1507.283447265625,
      "height": 180,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
