      "updated": 1780053920556,
      "link": null,
      "locked": false,
      "text": "\nTask deadlines & reminders\nBullMQ\nSchedule reminder emails or in-app pings before a task deadline using delayed BullMQ jobs.",
      "fontSize": 36,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "\nTask deadlines & reminders\nBullMQ\nSchedule reminder emails or in-app pings before a task deadline using delayed BullMQ jobs.",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "N3KledUf4lE50Mbbv5eOU",
      "type": "text",
      "x": -16472.916288623277,
      "y": -8734.155017694982,
