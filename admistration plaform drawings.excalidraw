      "updated": 1780053906527,
      "link": null,
      "locked": false,
      "text": "\nRead receipts\nRedis\nTrack who has seen a message. Stored in Redis for fast lookup, synced across servers.",
      "fontSize": 36,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "\nRead receipts\nRedis\nTrack who has seen a message. Stored in Redis for fast lookup, synced across servers.",
