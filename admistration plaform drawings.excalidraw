      "type": "text",
      "x": -16454.409251322344,
      "y": -8220.58473259407,
      "width": 1812.0595703125,
      "height": 225,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
